<%- include('./base/header.ejs')%>
<div class="container">
    <div class="row mt-1">
        <h2 class="text-center text-danger">List of Students</h2>
        <table class="table text-center">
            <tr>
                <th>
                    Roll No
                </th>
                <th>
                    Student Name
                </th>
                <th>
                    Father Name
                </th>
                <th>
                    AadharCard Number
                </th>
                <th>
                    Mobile No
                </th>
                <th>
                    Actions
                </th>
            </tr>
            <% students.forEach((student) => { %>
                <tr>
                    <td>
                        <%= student.rollNo %>
                    </td>
                    <td>
                        <%= student.studentName %>
                    </td>
                    <td>
                        <%= student.fatherName %>
                    </td>
                    <td>
                        <%= student.aadharCardNo %>
                    </td>
                    <td>
                        <%= student.mobileNo %>
                    </td>
                    <td>
                        <a href='student/edit/page/<%= student._id%>' class="btn btn-primary">
                            Edit Student
                        </a>
                    
                        <a href='/student/delete/<%= student._id%>' class="btn btn-danger">
                            Delete Student
                        </a>
                    </td>
                </tr>
           <% }) %>
        </table>
    </div>
</div> 
<%- include('./base/footer.ejs')%>