<%- include('./base/header.ejs') %>

    <div class="container mt-4">

        <h2 class="text-center" style="color: red;">Edit Student</h2>

        <form action="/update/student/<%= student.rollNo %>" method="POST">

            <div class="mb-3">
                <label>Roll No</label>
                <input type="text" class="form-control" name="rollNo" value="<%= student.rollNo %>">
            </div>

            <div class="mb-3">
                <label>Student Name</label>
                <input type="text" class="form-control" name="studentName" value="<%= student.studentName %>">
            </div>

            <div class="mb-3">
                <label>Father Name</label>
                <input type="text" class="form-control" name="fatherName" value="<%= student.fatherName %>">
            </div>

            <div class="mb-3">
                <label>Aadhar Number</label>
                <input type="text" class="form-control" name="aadharCardNo" value="<%= student.aadharCardNo %>">
            </div>

            <div class="mb-3">
                <label>Mobile Number</label>
                <input type="text" class="form-control" name="mobileNo" value="<%= student.mobileNo %>">
            </div>

            <button class="btn btn-success">
                Update Student
            </button>

        </form>

    </div>

    <%- include('./base/footer.ejs') %>